{
    "compilerOptions": {
        "module": "commonjs",
        "moduleResolution": "node",
        "target": "ES2020",
        "noEmitOnError": false,
        "strict": false,
        "skipLibCheck": true,
        "baseUrl": ".",
        "paths": {
            "vscode": [
                "unit/mocks/vscode"
            ]
        },
        "types": ["node", "mocha", "chai", "sinon"],
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "allowJs": true
    },
    "ts-node": {
        "compilerOptions": {
            "module": "commonjs"
        },
        "require": ["tsconfig-paths/register"]
    },
    "include": [
        "./**/*.ts",
        "./**/*.js"
    ],
    "exclude": ["../../node_modules"]
}