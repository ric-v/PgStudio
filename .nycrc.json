{
  "all": true,
  "include": [
    "src/services/handlers/**/*.ts",
    "src/providers/kernel/SqlParser.ts",
    "src/lib/**/*.ts",
    "src/utils/**/*.ts"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/test/**",
    "src/activation/**",
    "**/*.d.ts",
    "node_modules/**"
  ],
  "reporter": [
    "text",
    "text-summary",
    "html",
    "lcov",
    "json"
  ],
  "report-dir": "./coverage",
  "temp-dir": "./.nyc_output",
  "check-coverage": true,
  "lines": 85,
  "statements": 85,
  "functions": 80,
  "branches": 75,
  "per-file": false,
  "cache": true,
  "produce-source-map": true,
  "instrument": true,
  "require": [
    "ts-node/register"
  ],
  "extension": [
    ".ts"
  ],
  "watermarks": {
    "lines": [75, 85],
    "functions": [70, 80],
    "branches": [65, 75],
    "statements": [75, 85]
  }
}
